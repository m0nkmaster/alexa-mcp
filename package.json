{
  "name": "alexa-mcp",
  "version": "0.1.0",
  "description": "MCP server and CLI for Alexa devices and smart home control",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "alexa-mcp": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "cli": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "TEST_INTEGRATION=1 vitest run"
  },
  "keywords": [
    "alexa",
    "mcp",
    "smart-home",
    "echo",
    "model-context-protocol"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "commander": "^12.0.0",
    "undici": "^7.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
